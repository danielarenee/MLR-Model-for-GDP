# CARGAR DATOS
# ruta para dani
##df <- read.csv("/Users/danielarenee/Downloads/df_regresion_estandarizado.csv")
#ruta para mario
ruta_archivo <- file.choose()
df <- read.csv(ruta_archivo)
head(df)
#RLM inicial
PIB<-df$PIB
x1<- df$inflacion_subyacente
x2<- df$inflacion_no_subyacente
x3<- df$tasa_desocupacion
x4<- df$tasa_participacion
x5<- df$importaciones_manufactura
x6<- df$exportaciones_manufactura
x7<- df$formacion_bruta_capital_fijo
x8<- df$turismo_interior
x9<- df$prod_laboral_constructoras
x10<- df$tasa_informalidad_laboral
modelo0 <- lm(PIB ~ x1 + x2 + x3 + x4 + x5 + x6 + x7 + x8 + x9 + x10, data = df)
summary(modelo0)
correl0<-cor(cbind(x1,x2,x3,x4,x5,x6,x7,x8,x9,x10))
par(mfrow=c(1,1))
corrplot(correl0, type="upper", tl.col="tomato", tl.srt=60)
vif(modelo0)
# Planteamos x11 = exportaciones_manufactura - importaciones_manufactura
# quitamos x8 y x10 por vif
x11 <- df$exportaciones_manufactura - df$importaciones_manufactura
modelo1 <- lm(PIB ~ x1 + x2 + x3 + x4 + x7 + x9 + x11, data = df)
correl1<-cor(cbind(x1,x2,x3,x4,x7,x9,x11))
par(mfrow=c(1,1))
corrplot(correl1, type="upper", tl.col="tomato", tl.srt=60)
vif(modelo1) # ya se ve mejor !
# notamos la correlación entre las variables laborales...
# intentamos hacer PCA pero PC1 solo explica el 58% de la varianza
# incialmente pensamos en proponer una variable laboral con x3,x4 y x10
# pero ya sacamos x10, y x3 y x4 son redundantes entre sí
# por lo que nos quedamos únicamente con x4, que tiene más correlación
# con el PIB
modelo2 <- lm(PIB ~ x1 + x2 + x4 + x7 + x9 + x11, data = df)
correl2<-cor(cbind(x1,x2,x4,x7,x9,x11))
par(mfrow=c(1,1))
corrplot(correl2, type="upper", tl.col="tomato", tl.srt=60) # super bien!!
vif(modelo2) # super bien!!
summary(modelo2)
# calcular BIF , si nos salen bif altos y variables no sign, probar multicol
# ver valores influyentes y quitarlos
# calcular intervalos de confianza de los parametros
# incluso con 4 varibales
# metodo de seleccion de variables
###AQUI SE QUEDO DANI ,analisis de valores atipicos e influyentes ( no sacamos nada de ahi pero sirve para respladar)
################################################################################
# Diagnóstico de observaciones influyentes y ajuste del Modelo 2
# Modelo base: PIB ~ x1 + x2 + x4 + x7 + x9 + x11
# 1. Cálculo de métricas de diagnóstico
res_estud <- rstudent(modelo2)
leverage  <- hatvalues(modelo2)
dist_cook <- cooks.distance(modelo2)
n_obs <- nrow(df)
n_param <- length(coef(modelo2))
corte_leverage <- 2 * n_param / n_obs
# 2. Visualización de diagnósticos
# Configuramos la ventana gráfica para ver los 4 plots juntos
par(mfrow = c(2, 2), mar = c(4, 4, 2, 1))
# Plot 1: Residuales Estudentizados
plot(res_estud, pch = 16, col = "steelblue",
main = "Residuales Estudentizados", ylab = "r_i", xlab = "Índice")
abline(h = c(-2, 2), col = "firebrick", lty = 2)
atipicos <- which(abs(res_estud) > 2)
if(length(atipicos) > 0) text(atipicos, res_estud[atipicos], labels = atipicos, pos = 4, cex = 0.8, col = "firebrick")
# Plot 2: Leverages (Puntos de balanceo)
plot(leverage, pch = 16, col = "steelblue",
main = "Leverage (h_ii)", ylab = "h_ii", xlab = "Índice")
abline(h = corte_leverage, col = "firebrick", lty = 2)
puntos_balanceo <- which(leverage > corte_leverage)
if(length(puntos_balanceo) > 0) text(puntos_balanceo, leverage[puntos_balanceo], labels = puntos_balanceo, pos = 4, cex = 0.8, col = "firebrick")
# Plot 3: Distancia de Cook
plot(dist_cook, pch = 16, col = "steelblue",
main = "Distancia de Cook", ylab = "D_i", xlab = "Índice")
abline(h = 1, col = "firebrick", lty = 2)
influyentes <- which(dist_cook > 1)
if(length(influyentes) > 0) text(influyentes, dist_cook[influyentes], labels = influyentes, pos = 4, cex = 0.8, col = "firebrick")
# Plot 4: Leverage vs Cook
plot(leverage, dist_cook, pch = 16, col = "steelblue",
main = "Leverage vs Cook", xlab = "h_ii", ylab = "D_i")
abline(v = corte_leverage, col = "firebrick", lty = 2)
abline(h = 1, col = "firebrick", lty = 2)
# Restauramos parámetros gráficos originales
par(mfrow = c(1, 1))
# 3. Resumen de observaciones sospechosas
obs_sospechosas <- sort(unique(c(atipicos, puntos_balanceo, influyentes)))
cat("\n--- Resumen de Diagnóstico ---\n")
if(length(obs_sospechosas) > 0) {
resumen_diag <- data.frame(
Observacion = obs_sospechosas,
R_student   = round(res_estud[obs_sospechosas], 3),
Leverage    = round(leverage[obs_sospechosas], 4),
Cook_D      = round(dist_cook[obs_sospechosas], 4)
)
print(resumen_diag)
} else {
cat("No se detectaron observaciones altamente sospechosas.\n")
}
# Reestimación del modelo sin observaciones influyentes
obs_a_quitar <- which(dist_cook > 1)
if(length(obs_a_quitar) > 0) {
cat("\nEliminando observaciones:", paste(obs_a_quitar, collapse = ", "), "\n")
cat("Porcentaje de datos excluidos:", round(100 * length(obs_a_quitar) / n_obs, 2), "%\n\n")
# Detalles de lo que estamos quitando
print(df[obs_a_quitar, ])
# Creamos el dataset limpio
df_limpio <- df[-obs_a_quitar, ]
# Recalculamos la variable x11 para el nuevo dataset
df_limpio$x11 <- df_limpio$exportaciones_manufactura - df_limpio$importaciones_manufactura
# Ajustamos el nuevo modelo
modelo2_limpio <- lm(PIB ~ inflacion_subyacente + inflacion_no_subyacente +
tasa_participacion + formacion_bruta_capital_fijo +
prod_laboral_constructoras + x11,
data = df_limpio)
print(summary(modelo2_limpio))
cat("\n--- Comparación R2 Ajustado ---\n")
cat("Modelo original: ", round(summary(modelo2)$adj.r.squared, 4), "\n")
cat("Modelo limpio:   ", round(summary(modelo2_limpio)$adj.r.squared, 4), "\n")
} else {
cat("\nNo hay observaciones con Distancia de Cook > 1 para eliminar.\n")
}
# Ajuste alternativo: Incorporando variable Dummy por COVID
# Identificamos el periodo de pandemia (Q2 y Q3 2020)
df$dummy_covid <- ifelse(df$Periodo %in% c("2020/02", "2020/03"), 1, 0)
cat("\nTrimestres asignados a la dummy COVID:\n")
print(df$Periodo[df$dummy_covid == 1])
# Aseguramos que x11 esté en el dataset original
df$x11 <- df$exportaciones_manufactura - df$importaciones_manufactura
# Reestimamos incluyendo la variable indicadora
modelo2_covid <- lm(PIB ~ x1 + x2 + x4 + x7 + x9 + x11 + dummy_covid, data = df)
# print(summary(modelo2_covid)) # Descomentar para ver el summary completo
# print(vif(modelo2_covid))
cat("\n--- Comparación de Modelos (con vs sin Dummy) ---\n")
cat("R2 adj base:        ", round(summary(modelo2)$adj.r.squared, 4), "\n")
cat("R2 adj incl. COVID: ", round(summary(modelo2_covid)$adj.r.squared, 4), "\n")
cat("\nPrueba ANOVA para evaluar el aporte de la dummy COVID:\n")
print(anova(modelo2, modelo2_covid))
#no se usara
####################################################################################
# PRUEBA F PARCIAL: ¿x1, x2, x9 aportan al modelo?
################################################################################
# Modelo completo (modelo2)
MC <- lm(PIB ~ x1 + x2 + x4 + x7 + x9 + x11, data = df)
# Modelo reducido (solo variables significativas)
MR <- lm(PIB ~ x4 + x7 + x11, data = df)
# Prueba F parcial
anova(MR, MC)
#También F parciales individuales
# Quitar solo x1 (inflación subyacente)
MR_sin_x1 <- lm(PIB ~ x2 + x4 + x7 + x9 + x11, data = df)
cat("=== F parcial: x1 (inflacion subyacente) ===\n")
anova(MR_sin_x1, MC)
# Quitar solo x2 (inflación no subyacente)
MR_sin_x2 <- lm(PIB ~ x1 + x4 + x7 + x9 + x11, data = df)
cat("\n=== F parcial: x2 (inflacion no subyacente) ===\n")
anova(MR_sin_x2, MC)
# Quitar solo x9 (prod. laboral constructoras)
MR_sin_x9 <- lm(PIB ~ x1 + x2 + x4 + x7 + x11, data = df)
cat("\n=== F parcial: x9 (prod laboral constructoras) ===\n")
anova(MR_sin_x9, MC)
# COMPARAR TODOS LOS MODELOS CON AIC, BIC, R2 adj
cat("\n=== COMPARACION DE MODELOS ===\n")
cat("Modelo completo (x1+x2+x4+x7+x9+x11):\n")
cat("  R2 adj:", summary(MC)$adj.r.squared, "\n")
cat("  AIC:", AIC(MC), "\n")
cat("  BIC:", BIC(MC), "\n")
cat("\nModelo reducido (x4+x7+x11):\n")
cat("  R2 adj:", summary(MR)$adj.r.squared, "\n")
cat("  AIC:", AIC(MR), "\n")
cat("  BIC:", BIC(MR), "\n")
#Summaries
cat("\n=== SUMMARY MODELO REDUCIDO ===\n")
summary(MR)
#al final obs que no apartan al modelos las variables que quitamos, entonces nos quedamos
#con el modelo reducido
#######################################################################################
##Pruebas modelo original
ruta_archivo_org<- file.choose()
df_orig<- read.csv(ruta_archivo_org)
# MODELO EN UNIDADES ORIGINALES
ruta_archivo_org <- file.choose()
df_orig <- read.csv(ruta_archivo_org)
# Crear x11 COMO COLUMNA de df_orig (NO como variable global)
df_orig$x11_orig <- df_orig$exportaciones_manufactura - df_orig$importaciones_manufactura
# Modelo reducido en unidades originales
MR_orig <- lm(PIB ~ tasa_participacion + formacion_bruta_capital_fijo + x11_orig,
data = df_orig)
summary(MR_orig)
anova(MR_orig)
# MODELO ESTANDARIZADO (usa las x4, x7, x11 del inicio)
MR <- lm(PIB ~ x4 + x7 + x11, data = df)
summary(MR)
anova(MR)
# COMPARACION
cat("=== VERIFICACION DE ESCALAS ===\n")
cat("Media PIB estandarizado:", mean(df$PIB), "\n")
cat("Media PIB original:     ", mean(df_orig$PIB), "\n")
cat("SD PIB estandarizado:   ", sd(df$PIB), "\n")
cat("SD PIB original:        ", sd(df_orig$PIB), "\n")
cat("\n=== COMPARACION R2 ADJ ===\n")
cat("R2 adj estandarizado:", summary(MR)$adj.r.squared, "\n")
cat("R2 adj original:     ", summary(MR_orig)$adj.r.squared, "\n")
# ============================================
# VERIFICACIÓN DE SUPUESTOS - MODELO ESTANDARIZADO
# ============================================
library(lmtest)
cat("========================================\n")
cat("SUPUESTOS MODELO ESTANDARIZADO (MR)\n")
cat("========================================\n")
# --- 1. Normalidad ---
cat("\n--- 1. NORMALIDAD DE RESIDUOS ---\n")
shapiro.test(residuals(MR))
par(mfrow = c(1, 2))
hist(residuals(MR), breaks = 15, main = "Histograma de Residuos (Estandarizado)",
xlab = "Residuos", col = "steelblue", border = "white")
qqnorm(residuals(MR), pch = 19, col = "steelblue",
main = "QQ-Plot (Estandarizado)")
qqline(residuals(MR), col = "red", lwd = 2)
# --- 2. Homocedasticidad ---
cat("\n--- 2. HOMOCEDASTICIDAD ---\n")
bptest(MR)
par(mfrow = c(1, 1))
plot(fitted(MR), residuals(MR), pch = 19, col = "steelblue",
main = "Residuos vs Ajustados (Estandarizado)",
xlab = "Valores ajustados", ylab = "Residuos")
abline(h = 0, col = "red", lty = 2)
# --- 3. Independencia ---
cat("\n--- 3. INDEPENDENCIA ---\n")
cat("Durbin-Watson (autocorrelacion orden 1):\n")
dwtest(MR)
cat("\nLjung-Box (4 rezagos, 1 ano):\n")
Box.test(residuals(MR), lag = 4, type = "Ljung-Box")
cat("\nLjung-Box (8 rezagos, 2 anos):\n")
Box.test(residuals(MR), lag = 8, type = "Ljung-Box")
# ============================================
# VERIFICACIÓN DE SUPUESTOS - MODELO ORIGINAL
# ============================================
cat("\n\n========================================\n")
cat("SUPUESTOS MODELO ORIGINAL (MR_orig)\n")
cat("========================================\n")
# --- 1. Normalidad ---
cat("\n--- 1. NORMALIDAD DE RESIDUOS ---\n")
shapiro.test(residuals(MR_orig))
par(mfrow = c(1, 2))
hist(residuals(MR_orig), breaks = 15, main = "Histograma de Residuos (Original)",
xlab = "Residuos", col = "steelblue", border = "white")
qqnorm(residuals(MR_orig), pch = 19, col = "steelblue",
main = "QQ-Plot (Original)")
qqline(residuals(MR_orig), col = "red", lwd = 2)
# --- 2. Homocedasticidad ---
cat("\n--- 2. HOMOCEDASTICIDAD ---\n")
bptest(MR_orig)
par(mfrow = c(1, 1))
plot(fitted(MR_orig), residuals(MR_orig), pch = 19, col = "steelblue",
main = "Residuos vs Ajustados (Original)",
xlab = "Valores ajustados", ylab = "Residuos")
abline(h = 0, col = "red", lty = 2)
# --- 3. Independencia ---
cat("\n--- 3. INDEPENDENCIA ---\n")
cat("Durbin-Watson (autocorrelacion orden 1):\n")
dwtest(MR_orig)
cat("\nLjung-Box (4 rezagos, 1 ano):\n")
Box.test(residuals(MR_orig), lag = 4, type = "Ljung-Box")
cat("\nLjung-Box (8 rezagos, 2 anos):\n")
Box.test(residuals(MR_orig), lag = 8, type = "Ljung-Box")
